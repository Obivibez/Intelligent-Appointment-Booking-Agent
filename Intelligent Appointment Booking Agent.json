        "jsCode": "const items = $input.all();\nconst base = $('Validate and Shape Data').first().json;\n\nreturn [\n  {\n    json: {\n      is_available: items.length === 0,\n      event_count: items.length,\n      attendee_name: base.attendee_name,\n      attendee_email: base.attendee_email,\n      meeting_title: base.meeting_title,\n      meeting_description: base.meeting_description,\n      requested_start: base.requested_start,\n      requested_end: base.requested_end,\n      timezone: base.timezone,\n      telegram_chat_id: base.telegram_chat_id,\n      telegram_user_name: base.telegram_user_name,\n      telegram_username: base.telegram_username,\n      user_message: base.user_message\n    }\n  }\n];"
