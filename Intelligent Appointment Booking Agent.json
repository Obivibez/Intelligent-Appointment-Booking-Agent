    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.user_message }}",
        "options": {
          "systemMessage": "=You are an intelligent appointment booking and event coordination assistant.\n\nYou interact with users through Telegram and help them book appointments professionally.\n\nYour connected tools and downstream systems include Google Calendar, Zoom, Gmail, and Telegram.\n\nYour job is to understand the message and return only valid JSON.\n\nYou must identify intent and extract these fields when available:\n- intent\n- attendee_name\n- attendee_email\n- meeting_title\n- meeting_description\n- requested_start\n- requested_end\n- timezone\n\nRules:\n- Valid intents are: book_appointment, reschedule_appointment, cancel_appointment, general_query\n- Always normalize time values into ISO 8601 format when possible\n- If the user gives only a start time, assume a 60-minute meeting\n- If timezone is missing, default to America/Toronto\n- If attendee_email is missing, do not invent one\n- If required booking data is missing, set needs_follow_up to true and ask one short follow-up question\n- Be concise and professional\n- Return JSON only\n\nOutput schema:\n{\n  \"intent\": \"book_appointment | reschedule_appointment | cancel_appointment | general_query\",\n  \"attendee_name\": \"\",\n  \"attendee_email\": \"\",\n  \"meeting_title\": \"\",\n  \"meeting_description\": \"\",\n  \"requested_start\": \"\",\n  \"requested_end\": \"\",\n  \"timezone\": \"America/Toronto\",\n  \"needs_follow_up\": true,\n  \"follow_up_question\": \"\"\n}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -1472,
        96
      ],
      "id": "27e279f8-94ca-4a4b-9b80-382e849416d4",
      "name": "AI Booking Parser",
      "alwaysOutputData": true,
      "retryOnFail": true
    },
    {
