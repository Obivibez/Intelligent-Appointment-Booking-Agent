    {
      "parameters": {
        "jsCode": "let raw = $json.output || $json.text || $json.response || $json;\n\nif (typeof raw === 'string') {\n  raw = JSON.parse(raw);\n}\n\nfunction toIso(value) {\n  if (!value) return '';\n  const d = new Date(value);\n  if (isNaN(d.getTime())) return '';\n  return d.toISOString();\n}\n\nconst requestedStart = toIso(raw.requested_start);\nlet requestedEnd = toIso(raw.requested_end);\n\nif (requestedStart && !requestedEnd) {\n  const end = new Date(requestedStart);\n  end.setHours(end.getHours() + 1);\n  requestedEnd = end.toISOString();\n}\n\nreturn [\n  {\n    json: {\n      intent: raw.intent || 'general_query',\n      attendee_name: raw.attendee_name || '',\n      attendee_email: raw.attendee_email || '',\n      meeting_title: raw.meeting_title || 'Appointment Booking',\n      meeting_description: raw.meeting_description || 'Appointment scheduled through Telegram booking agent.',\n      requested_start: requestedStart,\n      requested_end: requestedEnd,\n      timezone: raw.timezone || 'America/Toronto',\n      needs_follow_up: !!raw.needs_follow_up,\n      follow_up_question: raw.follow_up_question || '',\n      telegram_chat_id: $('Normalize Telegram Input').first().json.telegram_chat_id,\n      telegram_user_name: $('Normalize Telegram Input').first().json.telegram_user_name,\n      telegram_username: $('Normalize Telegram Input').first().json.telegram_username,\n      user_message: $('Normalize Telegram Input').first().json.user_message\n    }\n  }\n];"
      },
